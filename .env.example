# =============================================================================
# n8n Private Deployment — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# ── n8n Version ───────────────────────────────────────────────────────────────
# Pin to a specific version in production (e.g. 1.45.0). "latest" is fine for dev.
N8N_VERSION=latest

# ── n8n Network ───────────────────────────────────────────────────────────────
N8N_PORT=5678
N8N_HOST=localhost
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/

# ── n8n Auth ──────────────────────────────────────────────────────────────────
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── n8n Encryption ────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=CHANGE_ME_32_CHAR_HEX_STRING

# ── Cookies ───────────────────────────────────────────────────────────────────
# Set to true when running behind HTTPS (recommended for production)
N8N_SECURE_COOKIE=false

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=n8n
POSTGRES_USER=n8n
# Generate with: openssl rand -hex 24
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# ── Timezone ──────────────────────────────────────────────────────────────────
GENERIC_TIMEZONE=Europe/Athens

# =============================================================================
# EGRESS WHITELIST — Domain Allowlist Configuration
# =============================================================================
# These variables are read by scripts/update-whitelist.sh to regenerate
# the Squid ACL file. Edit here, then run the script, then restart squid-proxy.

# Your company's primary domain (wildcarded automatically → *.company.com)
COMPANY_DOMAIN=yourcompany.com

# AI Copilot / LLM endpoint domain (wildcarded automatically)
# Examples:
#   api.openai.com       → OpenAI
#   api.anthropic.com    → Anthropic (Claude)
#   generativelanguage.googleapis.com → Google Gemini
#   api.mistral.ai       → Mistral
COPILOT_DOMAIN=api.openai.com

# Additional allowed domains (comma-separated, no spaces)
# Add any external APIs your workflows MUST reach.
# Leave empty to allow only COMPANY_DOMAIN and COPILOT_DOMAIN.
EXTRA_ALLOWED_DOMAINS=
